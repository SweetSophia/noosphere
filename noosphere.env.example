# Noosphere OpenClaw production defaults.
# Copy to ~/.noosphere/.env or let install-openclaw.sh generate one.
NOOSPHERE_VERSION=latest
NOOSPHERE_PORT=6578
APP_URL=http://127.0.0.1:6578
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_MIGRATION_PASSWORD=replace-with-distinct-migration-password
POSTGRES_APP_PASSWORD=replace-with-distinct-app-password
NEXTAUTH_SECRET=replace-with-strong-nextauth-secret
REDIS_URL=redis://redis:6379
# Direct Docker Compose users should set these so bootstrap credentials are known.
# install-openclaw.sh generates/stores its own values and does not require them here.
NOOSPHERE_ADMIN_PASSWORD=replace-with-strong-admin-password
# Set to true only when you intentionally want bootstrap to rotate an existing
# admin user's password to NOOSPHERE_ADMIN_PASSWORD.
NOOSPHERE_ADMIN_PASSWORD_RESET=false
# Set to true to re-assert the ADMIN role on the existing bootstrap admin
# account. Does NOT rotate the password — combine with
# NOOSPHERE_ADMIN_PASSWORD_RESET=true for a full rotation.
NOOSPHERE_FORCE_ADMIN=false
NOOSPHERE_BOOTSTRAP_API_KEY=noo_replace_with_32_plus_random_chars
# Used only if bootstrap has to auto-generate credentials. Set to
# /app/uploads/bootstrap-secrets/secrets.json if you want the file in the uploads volume.
NOOSPHERE_BOOTSTRAP_SECRETS_FILE=/tmp/noosphere-bootstrap-secrets/secrets.json
# Per-client-IP limit for POST /api/memory/recall. The default is sized for
# several local coding CLIs doing prompt-time recall through one shared IP.
NOOSPHERE_MEMORY_RECALL_RATE_LIMIT_PER_MINUTE=120

# Exact hybrid recall (optional Phase C). Keep this exact value until A3,
# Phase B, and Phase C are activated and one profile is serving with at least
# 95% current-vector coverage.
NOOSPHERE_HYBRID_RETRIEVAL_ENABLED=false
# NOOSPHERE_HYBRID_QUERY_PROFILE_ID=00000000-0000-4000-8000-000000000000
# The same provider mapping is used by the Phase B worker and Phase C queries.
# Encode compact provider JSON with: printf %s "$json" | base64 -w0
# NOOSPHERE_HYBRID_PROVIDER_CONFIG_B64=W10=
# NOOSPHERE_HYBRID_CACHE_HMAC_ACTIVE_VERSION=v1
# Generate a 32-64 byte random key, store it in a one-to-three-entry JSON
# object, then base64-encode that complete JSON. Never publish usable key data.
# NOOSPHERE_HYBRID_CACHE_HMAC_KEYS_B64=REPLACE_WITH_BASE64_ENCODED_KEYRING_JSON
# NOOSPHERE_HYBRID_REQUEST_TIMEOUT_MS=30000
# NOOSPHERE_HYBRID_MAX_RESPONSE_BYTES=4194304
