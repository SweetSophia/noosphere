# Noosphere OpenClaw production defaults.
# Copy to ~/.noosphere/.env or let install-openclaw.sh generate one.
NOOSPHERE_VERSION=latest
NOOSPHERE_PORT=6578
APP_URL=http://127.0.0.1:6578
POSTGRES_PASSWORD=replace-with-strong-postgres-password
NEXTAUTH_SECRET=replace-with-strong-nextauth-secret
REDIS_URL=redis://redis:6379
# Direct Docker Compose users should set these so bootstrap credentials are known.
# install-openclaw.sh generates/stores its own values and does not require them here.
NOOSPHERE_ADMIN_PASSWORD=replace-with-strong-admin-password
NOOSPHERE_BOOTSTRAP_API_KEY=noo_replace_with_32_plus_random_chars
