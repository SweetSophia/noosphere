{
  "name": "noosphere",
  "version": "1.6.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "test": "npm run test:memory && npm run test:cache && npm run test:api && npm run test:security",
    "test:memory": "node --import tsx --test 'src/__tests__/memory/**/*.test.ts'",
    "test:cache": "node --import tsx --test 'src/__tests__/cache/**/*.test.ts'",
    "test:api": "node --import tsx --test 'src/__tests__/api/**/*.test.ts'",
    "test:security": "node --import tsx --test src/__tests__/security/uploads.test.ts src/__tests__/security/proxy.test.ts",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx scripts/seed-topics.ts",
    "memory:scheduler": "tsx scripts/memory-scheduler.ts",
    "db:studio": "prisma studio",
    "version:sync": "node scripts/sync-version.mjs",
    "version:check": "node scripts/sync-version.mjs --check"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "ioredis": "^5.10.1",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.14",
    "hono": "4.12.18"
  }
}
