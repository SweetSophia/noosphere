# Noosphere — Environment Variables
# Copy this to .env and fill in the values

# ────────────────────────────────────────────
# Database
# ────────────────────────────────────────────
# Local PostgreSQL from the host (Docker Compose maps container 5432 to host 5433)
DATABASE_URL="postgresql://noosphere_migrator:CHANGE_ME_MIGRATION@localhost:5433/noosphere"
# Application processes use a distinct non-DDL identity. Compose constructs this
# URL from POSTGRES_APP_PASSWORD; set it directly for host-run development.
NOOSPHERE_APP_DATABASE_URL="postgresql://noosphere_app:CHANGE_ME_APP@localhost:5433/noosphere"
# One-time provisioning only. Never expose this URL to the application service.
NOOSPHERE_BOOTSTRAP_DATABASE_URL="postgresql://noosphere:CHANGE_ME_BOOTSTRAP@localhost:5433/noosphere"
# Optional, required only for local migration diff/dev workflows. Never point
# this at production; Prisma may reset it.
# SHADOW_DATABASE_URL="postgresql://noosphere:CHANGE_ME@localhost:5433/noosphere_shadow"

# ────────────────────────────────────────────
# NextAuth — Session authentication for humans
# ────────────────────────────────────────────
NEXTAUTH_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_32"
NEXTAUTH_URL="http://localhost:6578"

# ────────────────────────────────────────────
# App
# ────────────────────────────────────────────
APP_URL="http://localhost:6578"

# ────────────────────────────────────────────
# Database Connection Pool
# ────────────────────────────────────────────
# Tune these for your expected concurrent load.
# PG_POOL_MAX: max connections in the pool (default: 20)
# PG_IDLE_TIMEOUT_MS: close idle connections after this many ms (default: 30000)
# PG_CONN_TIMEOUT_MS: abort connection attempts after this many ms (default: 5000)
PG_POOL_MAX="20"
PG_IDLE_TIMEOUT_MS="30000"
PG_CONN_TIMEOUT_MS="5000"

# ────────────────────────────────────────────
# Security
# ────────────────────────────────────────────
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD="CHANGE_ME"
# These must be unique. Reusing POSTGRES_PASSWORD would let a leaked runtime
# credential authenticate as the bootstrap superuser and defeat role isolation.
POSTGRES_MIGRATION_PASSWORD="CHANGE_ME_MIGRATION"
POSTGRES_APP_PASSWORD="CHANGE_ME_APP"

# ────────────────────────────────────────────
# Redis (optional)
# ────────────────────────────────────────────
# Used for search result caching to speed up recall queries.
# If not set, the app runs normally without caching (just slower).
# For Docker Compose dev: redis://localhost:6379
REDIS_URL="redis://localhost:6379"

# ────────────────────────────────────────────
# Memory Recall Rate Limit
# ────────────────────────────────────────────
# Per-client-IP limit for POST /api/memory/recall.
# The default is sized for several local coding CLIs doing prompt-time recall.
NOOSPHERE_MEMORY_RECALL_RATE_LIMIT_PER_MINUTE="120"

# ────────────────────────────────────────────
# Automatic Memory Capture (Phase A foundation)
# ────────────────────────────────────────────
# Ingestion is disabled by default. Enabling this only opens the authenticated
# capture endpoint; the OpenClaw agent_end hook/extraction pipeline ships later.
# NOOSPHERE_AUTO_MEMORY_CAPTURE_ENABLED="false"
#
# Generate each key with at least 32 random bytes. Values use base64:<value>.
# Keep a maximum of three versions and select one active write version. Reads,
# dedupe, and session deletion check every retained version. Never retire an old
# key until the final capture written with it has exceeded the 30-day raw TTL
# plus the 90-day tombstone TTL (120 days after its last possible write).
# NOOSPHERE_MEMORY_CAPTURE_HMAC_ACTIVE_VERSION="1"
# NOOSPHERE_MEMORY_CAPTURE_HMAC_KEYS='{"1":"base64:REPLACE_WITH_32_RANDOM_BYTES_IN_BASE64"}'
#
# Privacy cleanup and expiry processing are independent of the ingestion flag.
# Run `npm run memory:scheduler`; this controls its polling interval only.
MEMORY_DURABLE_MAINTENANCE_INTERVAL_MS="60000"
