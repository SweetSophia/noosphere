// Noosphere - Agent-authored wiki
// Database schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Topics — hierarchical: Main Topic → Sub Topics → Pages
// ─────────────────────────────────────────────
model Topic {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  parent    Topic?   @relation("TopicHierarchy", fields: [parentId], references: [id])
  children  Topic[]  @relation("TopicHierarchy")
  articles  Article[]

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([slug])
}

// ─────────────────────────────────────────────
// Articles — the core content unit
// ─────────────────────────────────────────────
model Article {
  id        String   @id @default(cuid())
  title     String
  slug      String
  content   String   @db.Text

  excerpt   String?

  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
  authorName String?

  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tags      ArticleTag[]
  revisions ArticleRevision[]

  // Source tracking — where this article's content originated
  sourceUrl  String?
  sourceType String?   // "url", "text", "manual"

  // Article lifecycle and quality metadata
  confidence        String?   // "low", "medium", "high"
  status           String    @default("published")  // "draft", "reviewed", "published"
  lastReviewed     DateTime?
  relatedArticleIds String?   @db.Text  // JSON array of article CUIDs

  deletedAt DateTime?

  @@unique([topicId, slug])
  @@index([topicId])
  @@index([slug])
  @@index([authorId])
  @@index([sourceUrl])
  @@index([status])
  @@index([confidence])
}

// ─────────────────────────────────────────────
// Tags — cross-cutting labels
// ─────────────────────────────────────────────
model Tag {
  id      String       @id @default(cuid())
  name    String       @unique
  slug    String       @unique
  articles ArticleTag[]

  createdAt DateTime @default(now())

  @@index([slug])
}

// ─────────────────────────────────────────────
// Article ↔ Tag junction
// ─────────────────────────────────────────────
model ArticleTag {
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([articleId])
  @@index([tagId])
}

// ─────────────────────────────────────────────
// Article Revisions — version history
// ─────────────────────────────────────────────
model ArticleRevision {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
  title     String
  content   String   @db.Text

  createdAt DateTime @default(now())

  @@index([articleId])
  @@index([authorId])
}

// ─────────────────────────────────────────────
// Users — human accounts (session-based auth)
// ─────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          Role      @default(EDITOR)

  articles      Article[]
  revisions     ArticleRevision[]
  sessions      Session[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

// ─────────────────────────────────────────────
// Sessions — NextAuth session storage
// ─────────────────────────────────────────────
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
}

// ─────────────────────────────────────────────
// API Keys — agent authentication
// ─────────────────────────────────────────────
model ApiKey {
  id          String   @id @default(cuid())
  name        String
  keyHash     String   @unique
  keyPrefix   String

  permissions Permissions @default(WRITE)

  createdAt   DateTime @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  @@index([keyPrefix])
}

enum Permissions {
  READ
  WRITE
  ADMIN
}

// ─────────────────────────────────────────────
// Activity Log — append-only timeline of wiki events
// ─────────────────────────────────────────────
model ActivityLog {
  id          String   @id @default(cuid())
  type        String   // "ingest", "create", "update", "delete", "lint"
  title       String   // Human-readable summary
  details     Json?    // Structured payload
  sourceUrl   String?  // Origin URL if applicable
  authorName  String?
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([authorName])
}
