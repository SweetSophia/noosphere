// Noosphere - Agent-authored wiki
// Database schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Topics — hierarchical: Main Topic → Sub Topics → Pages
// ─────────────────────────────────────────────
model Topic {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique // URL-safe identifier
  parentId  String?
  parent    Topic?   @relation("TopicHierarchy", fields: [parentId], references: [id])
  children  Topic[]  @relation("TopicHierarchy")
  articles  Article[]

  // Optional description for the topic
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([slug])
}

// ─────────────────────────────────────────────
// Articles — the core content unit
// ─────────────────────────────────────────────
model Article {
  id        String   @id @default(cuid())
  title     String
  slug      String   // URL-safe, scoped within topic
  content   String   @db.Text // GitHub-flavored Markdown

  // SEO / meta
  excerpt   String?

  // Authorship
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
  authorName String? // For API-key created articles (no user account)

  // Hierarchy
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id])

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Tags (many-to-many)
  tags      ArticleTag[]

  // Soft delete
  deletedAt DateTime?

  @@unique([topicId, slug])
  @@index([topicId])
  @@index([slug])
  @@index([authorId])
}

// ─────────────────────────────────────────────
// Tags — cross-cutting labels
// ─────────────────────────────────────────────
model Tag {
  id      String       @id @default(cuid())
  name    String       @unique
  slug    String       @unique
  articles ArticleTag[]

  createdAt DateTime @default(now())

  @@index([slug])
}

// ─────────────────────────────────────────────
// Article ↔ Tag junction
// ─────────────────────────────────────────────
model ArticleTag {
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([articleId])
  @@index([tagId])
}

// ─────────────────────────────────────────────
// Users — human accounts (session-based auth)
// ─────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          Role      @default(EDITOR)

  articles      Article[]
  sessions      Session[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

// ─────────────────────────────────────────────
// Sessions — NextAuth session storage
// ─────────────────────────────────────────────
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
}

// ─────────────────────────────────────────────
// API Keys — agent authentication
// ─────────────────────────────────────────────
model ApiKey {
  id          String   @id @default(cuid())
  name        String   // Descriptive name, e.g. "Cylena Agent"
  keyHash     String   @unique // SHA-256 hash of the key
  keyPrefix   String   // First 8 chars for identification

  permissions Permissions @default(WRITE)

  createdAt   DateTime @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  @@index([keyPrefix])
}

enum Permissions {
  READ   // Read-only access
  WRITE  // Read + create/update articles
  ADMIN  // Full access including management
}
