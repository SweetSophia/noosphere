{
  "name": "@sweetsophia/openclaw-noosphere-memory",
  "version": "0.1.0",
  "private": false,
  "description": "OpenClaw plugin for Noosphere memory status, recall tools, and optional auto-recall prompt injection.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/",
    "src/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p build-tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "@sweetsophia/openclaw-noosphere-memory",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.3-1"
    },
    "compat": {
      "pluginApi": ">=2026.5.3-1",
      "minGatewayVersion": "2026.5.3-1"
    }
  }
}
